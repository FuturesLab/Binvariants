+static inline void binv_wait_tsl(CPUState *cpu, struct afl_tsl t) {
+  TranslationBlock *tb, *last_tb;
+  u8 invalid_pc = 0;
+
+  tb = afl_tb_lookup(cpu, t.tb.pc, t.tb.cs_base, t.tb.flags, t.tb.cf_mask);
+
+  if (!tb) {
+    if (is_valid_addr(t.tb.pc)) {
+      struct binv_args ba;
+
+      mmap_lock();
+      if (Binv_qemu_initialized) {
+        if (t.need_regs) {
+          ba.cur_reg_values = t.reg_values;
+          ba.cur_acc_regs_array = t.acc_regs_array;
+          ba.cur_acc_regs_cnt = t.acc_regs_cnt;
+          ba.cur_binv_id = t.binv_id;
+        }
+      }
+
+      if (t.need_regs) {
+        tb = tb_gen_code(cpu, t.tb.pc, t.tb.cs_base, t.tb.flags, t.tb.cf_mask, &ba, NULL);
+      } else {
+        tb = tb_gen_code(cpu, t.tb.pc, t.tb.cs_base, t.tb.flags, t.tb.cf_mask, NULL, NULL);
+      }
+      
+      tb->acc_regs_array = NULL;
+      mmap_unlock();
+
+    } else {
+
+      invalid_pc = 1;
+
+    }
+  }
+
+  if (t.is_chain && !invalid_pc) {
+
+    last_tb = afl_tb_lookup(cpu, t.chain.last_tb.pc,
+                               t.chain.last_tb.cs_base,
+                               t.chain.last_tb.flags,
+                               t.chain.cf_mask);
+#define TB_JMP_RESET_OFFSET_INVALID 0xffff
+      if (last_tb && (last_tb->jmp_reset_offset[t.chain.tb_exit] !=
+                      TB_JMP_RESET_OFFSET_INVALID)) {
+
+        tb_add_jump(last_tb, t.chain.tb_exit, tb);
+
+      }
+
+  }
+}
+
+static inline void binv_wait_update_invs(CPUState *cpu, struct binv_invs b) {
+  BinvariantsTB *curtb_binvTB = &binvTB[b.binv_id];
+  curtb_binvTB->invs_cnt = b.invs_cnt;
+  memcpy(curtb_binvTB->invs, b.invs, b.invs_cnt * sizeof(uint16_t));
+}
+
+static inline ssize_t read_exact(int fd, void *buf, size_t len) {
+    size_t got = 0;
+    while (got < len) {
+        ssize_t r = read(fd, (char*)buf + got, len - got);
+        if (r <= 0) return r;
+        got += r;
+    }
+    return got;
+}
+
+static inline void write_exact(int fd, const void *buf, size_t n) {
+  const uint8_t *p = buf;
+  while (n) {
+      ssize_t w = write(fd, p, n);
+      if (w <= 0) perror("write"), exit(1);
+      p += w; n -= w;
+  }
+}
+
+void binv_send_whole(int fd, enum binv_msg_type type, const void *m) {
+  if (type == MSG_TSL) {
+    struct binv_msg_tsl msg;
+    
+    msg.hdr.type = MSG_TSL;
+    msg.hdr.len  = htons(sizeof(struct afl_tsl));
+    msg.payload  = *(const struct afl_tsl *)m;
+
+    write_exact(fd, &msg, sizeof(msg));
+  } else {
+    struct binv_msg_binv msg;
+    
+    msg.hdr.type = MSG_BINV;
+    msg.hdr.len  = htons(sizeof(struct binv_invs));
+    msg.payload  = *(const struct binv_invs *)m;
+
+    write_exact(fd, &msg, sizeof(msg));
+  }
+}
+
+static void binv_wait_tsl_or_update_invs(CPUState *cpu, int fd) {
+  while (1) {
+    struct binv_msg_hdr hdr;
+    if (read_exact(fd, &hdr, sizeof(struct binv_msg_hdr)) != sizeof(struct binv_msg_hdr)) break;
+
+    uint16_t payload_len = ntohs(hdr.len);
+    void *payload = malloc(payload_len);
+    if (!payload) {
+      perror("malloc");
+      break;
+    }
+
+    if (read_exact(fd, payload, payload_len) != payload_len) {
+      free(payload);
+      break;
+    }
+
+    if (hdr.type == MSG_TSL) {
+      struct afl_tsl *t_ptr = (struct afl_tsl *)payload;
+      if (t_ptr->tb.pc == (target_ulong)-1) {
+        free(payload);
+        close(fd);
+        return;
+      }
+      binv_wait_tsl(cpu, *t_ptr);
+    } else if (hdr.type == MSG_BINV) {
+      struct binv_invs *b_ptr = (struct binv_invs *)payload;
+      binv_wait_update_invs(cpu, *b_ptr);
+    } else {
+      // pass
+    }
+    free(payload);
+  }
+  close(fd);
+}
+
+static void binv_request_tsl(target_ulong pc, target_ulong cb, uint32_t flags,
+                            uint32_t cf_mask, TranslationBlock *last_tb,
+                            int tb_exit, CPUState *cpu, TranslationBlock *cur_tb) {
+  if (disable_caching) return;
+
+  struct afl_tsl t;
+
+  if (!afl_fork_child) return;
+
+  t.tb.pc = pc;
+  t.tb.cs_base = cb;
+  t.tb.flags = flags;
+  t.tb.cf_mask = cf_mask;
+  t.is_chain = (last_tb != NULL);
+  t.need_regs = 0;
+  t.acc_regs_cnt = 0;
+  memset(t.acc_regs_array, 0, sizeof t.acc_regs_array);
+
+  if (Binv_qemu_initialized) {
+    if (cur_tb->binv_id && cur_tb->acc_regs_array && cur_tb->acc_regs_cnt) {
+      CPUArchState *env = cpu->env_ptr;
+
+      t.need_regs = 1;
+      t.binv_id = cur_tb->binv_id;
+
+      for (int i = 0; i < NUM_REGS; i++) {
+        t.reg_values[i] = env->regs[i];
+      }
+
+      memcpy(t.acc_regs_array, cur_tb->acc_regs_array, cur_tb->acc_regs_cnt * sizeof(uint8_t));
+      t.acc_regs_cnt = cur_tb->acc_regs_cnt;
+
+      free(cur_tb->acc_regs_array);
+      cur_tb->acc_regs_array = NULL;
+    }
+  }
+
+  if (t.is_chain) {
+
+    t.chain.last_tb.pc = last_tb->pc;
+    t.chain.last_tb.cs_base = last_tb->cs_base;
+    t.chain.last_tb.flags = last_tb->flags;
+    t.chain.cf_mask = cf_mask;
+    t.chain.tb_exit = tb_exit;
+
+  }
+  
+  binv_send_whole(TSL_FD, MSG_TSL, &t);
+}
+
+/* reflect updated invs to QEMU parent*/
+void binv_request_update_invs(BinvariantsTB *curtb_binvTB) {
+  struct binv_invs b;
+
+  b.binv_id = curtb_binvTB->binv_id;
+  b.invs_cnt = curtb_binvTB->invs_cnt;
+  memcpy(b.invs, curtb_binvTB->invs, b.invs_cnt * sizeof(uint16_t));
+
+  binv_send_whole(TSL_FD, MSG_BINV, &b);
+}
