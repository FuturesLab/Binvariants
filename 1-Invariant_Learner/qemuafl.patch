+        exit(1);
+    }
+
+    cs_option(binv_handle, CS_OPT_SKIPDATA, CS_OPT_ON);
+
+    switch (info->cap_arch) {
+    case CS_ARCH_SYSZ:
+        cs_option(binv_handle, CS_OPT_SKIPDATA_SETUP,
+                  (uintptr_t)&cap_skipdata_s390x);
+        break;
+
+    case CS_ARCH_X86:
+        cs_option(binv_handle, CS_OPT_SYNTAX, CS_OPT_SYNTAX_ATT);
+        break;
+    }
+
+    binv_cap_insn = cs_malloc(binv_handle);
+    if (binv_cap_insn == NULL) {
+        cs_close(binv_handle);
+        fprintf(stderr, "ERROR: Failed to malloc binv_cap_insn\n");
+        exit(1);
+    }
+}
+
+void *Binvariants_cap_disas(disassemble_info *info, uint64_t pc, size_t size) {
+    uint8_t cap_buf[32];
+    const uint8_t *cbuf = cap_buf;
+
+    assert(size < sizeof(cap_buf));
+    info->read_memory_func(pc, cap_buf, size, info);
+
+    cs_disasm_iter(binv_handle, &cbuf, &size, &pc, binv_cap_insn);
+
+    return binv_cap_insn;
+}
